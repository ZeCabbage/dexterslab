# ── dexterslab edge-daemon Environment Template ──────────────────────
# NEVER commit .env to git.
# Last updated: 2026-04-03

# ── Cloudflare Tunnel Hostnames ───────────────────────────────────
PC_BACKEND_URL=dexterslab-api.cclottaaworld.com   # Required
PC_FRONTEND_URL=dexterslab.cclottaaworld.com      # For kiosk display URL

# ── Health Server ─────────────────────────────────────────────────
HEALTH_PORT=8891               # Local health endpoint (not exposed via CF)

# ── Camera Config ─────────────────────────────────────────────────
CAMERA_DEVICE=/dev/video0      # default '/dev/video0'
CAMERA_WIDTH=320               # default 320
CAMERA_HEIGHT=240              # default 240
CAMERA_FPS=15                  # default 15

# ── Audio Config ──────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000        # default 16000
AUDIO_CHANNELS=1               # default 1
AUDIO_CHUNK_MS=100             # default 100

# ── System Config ─────────────────────────────────────────────────
TTS_ENGINE=espeak-ng           # default 'espeak-ng'
LOG_LEVEL=INFO                 # default 'INFO'
