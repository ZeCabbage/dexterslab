# ── dexterslab-backend Environment Template ──────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to git. NEVER share this file outside the PC Hub.
# Last updated: [DATE]

# ── Runtime ──────────────────────────────────────────────────────
PORT=8888
NODE_ENV=development
PLATFORM=                      # Required: 'windows' | 'pi' | 'mac'

# ── AI Services (PC Hub only — never on Pi or frontend) ──────────
GEMINI_API_KEY=                # Rotate at: console.cloud.google.com

# ── Observer ─────────────────────────────────────────────────────
OBSERVER_MODE=v2               # Only valid value is 'v2'

# ── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=               # http://localhost:3000,https://dexterslab.cclottaaworld.com

# ── Inter-Node Network (Tailscale IPs ONLY) ───────────────────────
PI_TAILSCALE_IP=               # e.g. 100.x.x.x
#                      # Get from: tailscale status on Pi
#                      # Never commit the real value here
MAC_TAILSCALE_IP=              # e.g. 100.x.x.x

# ── Edge Daemon Ports ─────────────────────────────────────────────
VIDEO_UDP_PORT=5600            # Pi streams video here
AUDIO_WS_PORT=8889             # Pi streams audio here
TTS_COMMAND_PORT=8890          # PC sends TTS commands to Pi here

# ── Cognitive Layer ───────────────────────────────────────────────
MEMORY_DB_PATH=./data/dexterslab-memory.db
MEMORY_RETENTION_DAYS=30
# JSON config for spatial zones — leave empty for default 3x3 grid
SPATIAL_ZONE_CONFIG=

# ── Admin Dashboard ──────────────────────────────────────────────
# Required for admin dashboard access. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never commit the actual value. Store only in .env on the PC Hub.
ADMIN_SECRET_TOKEN=

# ── Gemini Rate Limiting ──────────────────────────────────────────
# Adjust based on your Gemini API tier and budget
GEMINI_MAX_CALLS_PER_MINUTE=10     # Conservative default
GEMINI_MAX_CALLS_PER_HOUR=100      # Daily budget guard
GEMINI_MIN_INTERVAL_MS=3000        # Minimum 3s between calls

# ── Entity Classification Thresholds ─────────────────────────────
# Adjust based on your installation traffic volume.
# Low traffic (home office): lower these values significantly.
# High traffic (public kiosk): keep defaults or increase.
#
# Classification logic:
#   resident:  visits >= RESIDENT_MIN_VISITS 
#              AND avg_duration >= RESIDENT_MIN_AVG_DURATION_SECONDS
#   visitor:   visits >= VISITOR_MIN_VISITS 
#              AND avg_duration >= VISITOR_MIN_AVG_DURATION_SECONDS
#   passerby:  avg_duration < PASSERBY_MAX_DURATION_SECONDS
#   unknown:   visits <= UNKNOWN_MAX_VISITS (not enough data)

ENTITY_RESIDENT_MIN_VISITS=10
ENTITY_RESIDENT_MIN_AVG_DURATION_SECONDS=300
ENTITY_VISITOR_MIN_VISITS=2
ENTITY_VISITOR_MIN_AVG_DURATION_SECONDS=60
ENTITY_PASSERBY_MAX_DURATION_SECONDS=30
ENTITY_UNKNOWN_MAX_VISITS=2


