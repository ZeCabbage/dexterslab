# dexterslab SSH Configuration (Cloudflare Tunnel)
#
# All Pi SSH access goes through Cloudflare Tunnel.
# Requires cloudflared installed on the connecting machine.
# Install: https://developers.cloudflare.com/cloudflare-one/connections/connect-networks/downloads/
#
# Replace [PC_USERNAME] with your actual Windows username.

# SSH to Pi via Cloudflare Tunnel (for interactive use)
Host dexterslab-pi
    HostName pi.dexterslab.cclottaaworld.com
    User deploy
    IdentityFile ~/.ssh/dexterslab_pi_ed25519
    ForwardAgent no
    ServerAliveInterval 30
    ServerAliveCountMax 3
    ProxyCommand cloudflared access ssh --hostname %h

# SSH to Pi via Cloudflare Tunnel (for deployment scripts)
Host pi-deploy
    HostName pi.dexterslab.cclottaaworld.com
    User deploy
    IdentityFile ~/.ssh/pc_to_pi_deploy
    ForwardAgent no
    ProxyCommand cloudflared access ssh --hostname %h

# SSH to PC (local — no tunnel needed since you're on the PC)
Host dexterslab-pc
    HostName localhost
    User [PC_USERNAME]
    IdentityFile ~/.ssh/dexterslab_ed25519
    ForwardAgent no
